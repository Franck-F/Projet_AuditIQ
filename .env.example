# =============================================================================
# AuditIQ — environment template
# Copy to .env.local (web) and .env (api). Never commit filled values.
# =============================================================================

# ----- Supabase (shared) -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side: same project URL as NEXT_PUBLIC_SUPABASE_URL, but exposed under
# a non-public name so the API's pydantic-settings can read it. The API uses
# this to derive the JWKS endpoint for ES256 token verification — without it,
# every authenticated request returns 401 "clé de signature introuvable".
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Server-side only, never expose
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ----- Web (apps/web) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- API (apps/api) -----
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_LOG_LEVEL=info
API_RATE_LIMIT_DEFAULT=60/minute
API_RATE_LIMIT_AUTH=10/minute

# ----- LLM providers -----
# Primary
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
# Fallback (Enterprise / sovereignty)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
# Provider selection: "gemini" | "mistral"
LLM_PROVIDER_DEFAULT=gemini

# ----- Storage (Supabase Storage buckets) -----
STORAGE_BUCKET_DATASETS=datasets
STORAGE_BUCKET_REPORTS=reports
STORAGE_SIGNED_URL_TTL_SECONDS=900

# ----- PDF service (Puppeteer) -----
PDF_SERVICE_URL=http://localhost:3001
PDF_SERVICE_SECRET=change-me-long-random-string

# ----- Observability (optional in dev) -----
SENTRY_DSN_WEB=
SENTRY_DSN_API=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ----- Email (Resend or similar) -----
RESEND_API_KEY=
EMAIL_FROM=AuditIQ <no-reply@auditiq.example>

# ----- Misc -----
DEFAULT_LOCALE=fr-FR
DATA_RETENTION_DAYS=30
