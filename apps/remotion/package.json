{
  "name": "@auditiq/remotion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:mp4": "remotion render src/index.ts comment-ca-marche ../web/public/video/comment-ca-marche.mp4 --codec=h264 --crf=20",
    "render:webm": "remotion render src/index.ts comment-ca-marche ../web/public/video/comment-ca-marche.webm --codec=vp9 --crf=32",
    "render:poster": "remotion still src/index.ts comment-ca-marche ../web/public/video/comment-ca-marche-poster.jpg --frame=15 --image-format=jpeg --jpeg-quality=88",
    "render:all": "pnpm render:mp4 && pnpm render:webm && pnpm render:poster",
    "lint": "true",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.250",
    "@remotion/cli": "4.0.250",
    "@remotion/google-fonts": "4.0.250",
    "@remotion/renderer": "4.0.250",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.250"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.6.3"
  }
}
